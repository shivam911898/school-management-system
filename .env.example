PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/school-management
REQUIRE_DB=false
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
COOKIE_EXPIRES_IN_DAYS=7

# Optional Firebase Admin credentials for push notifications.
# Prefer a single JSON string in production (Render secret env var):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Alternatively use individual keys below:
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# SMTP settings for sending password reset emails
# If not provided, Ethereal test account will be used in development
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM="School <no-reply@school.example>"

# Twilio SMS settings for SMS-based password recovery
# Sign up free at https://www.twilio.com
# Get SID, Auth Token from Twilio Console
# Phone number must be your Twilio phone (e.g., +1234567890)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
